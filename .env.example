# Pusher Configuration
# Get your credentials from https://dashboard.pusher.com/

# Client-side (public, exposed to browser)
NEXT_PUBLIC_PUSHER_APP_KEY=your-pusher-key

# Server-side (private, used in server actions)
PUSHER_APP_ID=your-pusher-app-id
PUSHER_APP_KEY=your-pusher-key
PUSHER_APP_SECRET=your-pusher-secret

# Note: Pusher cluster is hardcoded to 'ap2' in lib/pusher-server.ts and lib/pusher-client.ts
# Change if your app uses a different cluster
